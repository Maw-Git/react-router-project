components/Article.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Profile.js",["114"],[],"import React from \"react\";\nimport { useSelector } from \"react-redux\";\nimport { Link } from \"react-router-dom\";\nimport { selectCurrentUser, selectIsLoggedIn } from \"../features/session/sessionSlice\";\n\nexport default function Profile () {\n  const currentUser = useSelector(selectCurrentUser)\n  const loggedIn = useSelector(selectIsLoggedIn);\n  \n  // use loggedIn to return a Navigate\n\n  return (\n    <main>\n      <h1>{currentUser.username}</h1>\n      <Link to={`edit`}>Edit</Link>\n      {/* Tell React Router where to render child routes` */}\n    </main>\n  )\n}\n","/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/EditProfileForm.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Author.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Categories.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Category.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Root.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/features/authors/authorsSlice.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/features/categories/categoriesSlice.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/features/articles/articlesSlice.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/features/session/sessionSlice.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Search.js",[],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Header.js",["115"],[],"/Users/mauriciopena/CodeCademy/react-router-project/starting_code/src/components/Footer.js",[],[],"/Users/maurici